<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!-- Salida a CONSOLA en formato JSON -->
    <appender name="JSON_CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <!-- Zona horaria de México -->
            <timeZone>America/Mexico_City</timeZone>
        </encoder>
    </appender>

    <!-- Salida a ARCHIVO en formato JSON (opcional) -->
    <appender name="JSON_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>logs/aplicacion.json</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <!-- Un archivo por día, conserva 7 días -->
            <fileNamePattern>logs/aplicacion-%d{yyyy-MM-dd}.json</fileNamePattern>
            <maxHistory>7</maxHistory>
        </rollingPolicy>
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <timeZone>America/Mexico_City</timeZone>
        </encoder>
    </appender>

    <!-- Nivel general -->
    <root level="INFO">
        <appender-ref ref="JSON_CONSOLE"/>
        <appender-ref ref="JSON_FILE"/>
    </root>

    <!-- Tu paquete con nivel INFO -->
    <logger name="com.ejemplo.demo" level="INFO"/>

</configuration>








