package com.ejemplo.demo.config;

import lombok.extern.slf4j.Slf4j;
import net.logstash.logback.argument.StructuredArguments;
import org.aspectj.lang.JoinPoint;
import org.aspectj.lang.annotation.*;
import org.springframework.stereotype.Component;
import java.util.Arrays;

@Slf4j
@Aspect
@Component
public class LoggingAspect {

    @AfterReturning(
        pointcut = "execution(* com.ejemplo.demo.service..*(..))",
        returning = "resultado")
    public void cuandoTermina(JoinPoint jp, Object resultado) {
        log.info("Servicio ejecutado correctamente",
                 StructuredArguments.keyValue("metodo", jp.getSignature().toShortString()),
                 StructuredArguments.keyValue("estado", "OK"),
                 StructuredArguments.keyValue("argumentos", Arrays.toString(jp.getArgs())),
                 StructuredArguments.keyValue("resultado", String.valueOf(resultado)));
    }

    @AfterThrowing(
        pointcut = "execution(* com.ejemplo.demo.service..*(..))",
        throwing = "error")
    public void cuandoFalla(JoinPoint jp, Throwable error) {
        log.error("Error en la ejecución del servicio",
                  StructuredArguments.keyValue("metodo", jp.getSignature().toShortString()),
                  StructuredArguments.keyValue("estado", "ERROR"),
                  StructuredArguments.keyValue("argumentos", Arrays.toString(jp.getArgs())),
                  StructuredArguments.keyValue("causa", error.getMessage()));
    }
}
